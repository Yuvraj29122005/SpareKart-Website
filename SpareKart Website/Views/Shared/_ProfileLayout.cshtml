<!DOCTYPE html>
<html>
<head>
    <title>SpareKart</title>

    <link rel="stylesheet" href="~/css/profilelayout.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/profile.css" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
</head>

<body>

    <!-- PROFILE NAVBAR -->

    <div class="profile-navbar">

        <div class="nav-left">
            <a href="/Home/Index">
                <img src="~/images/logo.png" class="nav-logo" alt="SpareKart" />
            </a>
        </div>

        <div class="nav-center">
            <a href="/Home/Index" style="text-decoration:none;">
                <span style="color:#2563eb;font-weight:800;">Spare</span><span style="color:#f97316;font-weight:800;">Kart</span>
            </a>
        </div>

        <div class="nav-right">
            @using Microsoft.AspNetCore.Http
            @using SpareKart_Website.Data
            @inject IHttpContextAccessor HttpContextAccessor
            @inject ApplicationDbContext Context

            @{
                var userId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
                SpareKart_Website.Models.User currentUser = null;
                if (userId != null)
                {
                    currentUser = Context.Users.FirstOrDefault(u => u.Id == userId);
                }
            }

            @if (currentUser != null)
            {
                <div class="user-nav-info" style="display: flex; align-items: center; gap: 10px; margin-right: 15px;">
                    @if (!string.IsNullOrEmpty(currentUser.ProfilePictureUrl))
                    {
                        <img src="/@currentUser.ProfilePictureUrl" alt="Profile" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 2px solid #fff;" />
                    }
                    else
                    {
                        <i class="fa fa-user-circle" style="font-size: 24px; color: #fff;"></i>
                    }
                    <span style="color: #fff; font-weight: 500;">@currentUser.Name.Split(' ')[0]</span>
                </div>
            }

            <a href="/Profile/Logout">
                <button class="logout-btn">
                    <i class="fa fa-sign-out"></i> Logout
                </button>
            </a>
        </div>

    </div>

    @RenderBody()

    <!-- ============================
         FOOTER
         ============================ -->
    <footer class="footer">
        <div class="footer-inner">

            <div class="f-col">
                <h4>About <span style="color:#3b82f6;">Spare</span><span style="color:#f97316;">Kart</span></h4>
                <p>
                    Spare Kart is an online<br />
                    store providing quality<br />
                    car spare parts at<br />
                    affordable prices with<br />
                    fast, reliable service.
                </p>
            </div>

            <div class="f-col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/Home/Index">Home</a></li>
                    <li><a href="/Products/AllProducts">Products</a></li>
                    <li><a href="/Order/MyOrders">Orders</a></li>
                </ul>
            </div>

            <div class="f-col">
                <h4>Support</h4>
                <div class="f-support-row">
                    <a href="/Feedback/Index">Feedback</a>
                </div>
                <div class="f-support-row">
                    <i class="fa-regular fa-envelope"></i>
                    <span>ydhadhal15@rku.ac.in</span>
                </div>
                <div class="f-support-row">
                    <i class="fa-solid fa-phone"></i>
                    <span>+91 81403 51044</span>
                </div>
            </div>

            <div class="f-col">
                <h4>Follow Us</h4>
                <div class="f-socials">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

        </div>

        <hr class="f-divider" />

        <p class="f-copy">
            &copy; 2026 <span style="color:#3b82f6;font-weight:700;">Spare</span><span style="color:#f97316;font-weight:700;">Kart</span> Car Parts. All rights reserved.
        </p>
    </footer>
    <!-- END FOOTER -->

</body>
</html>