<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel – SpareKart</title>

    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Admin Layout CSS (in admin subfolder) -->
    <link rel="stylesheet" href="~/css/admin/adminLayout.css" />
    <style>
        .admin-nav-links .btn-logout:hover {
            background: #dc2626 !important;
            color: #ffffff !important;
        }
    </style>
</head>

<body>

    <div class="admin-main">

        <!-- ===== SIDEBAR ===== -->
        <div class="admin-sidebar">

            <div class="admin-brand">
                <div class="brand-icon">
                    <i class="fa-solid fa-laptop-code" style="color: #fff; font-size: 14px;"></i>
                </div>
                <div class="brand-text">
                    <h5 class="admin-logo">SpareKart</h5>
                    <p class="admin-panel text-success">Active Group</p>
                </div>
            </div>

            @{
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            }

            <div class="admin-nav-links">
                <a href="/Admin/Dashboard" class="@(currentAction == "Dashboard" ? "active" : "")">
                    <i class="fa fa-desktop"></i> Dashboard
                </a>
                <a href="/Admin/Products" class="@(currentAction == "Products" || currentAction == "AddProduct" || currentAction == "EditProduct" ? "active" : "")">
                    <i class="fa fa-box"></i> Products
                </a>
                <a href="/Admin/Orders" class="@(currentAction == "Orders" || currentAction == "OrderDetails" ? "active" : "")">
                    <i class="fa fa-clipboard-list"></i> Orders
                </a>
                <a href="/Admin/Users" class="@(currentAction == "Users" ? "active" : "")">
                    <i class="fa fa-users"></i> Users
                </a>
                <a href="/Admin/Feedback" class="@(currentAction == "Feedback" ? "active" : "")">
                    <i class="fa fa-comment-dots"></i> Feedback
                </a>
                <a href="/Admin/Profile" class="@(currentAction == "Profile" ? "active" : "")" style="margin-top: 24px;">
                    <i class="fa fa-user-circle"></i> Profile
                </a>
                <a href="#" class="btn-logout" style="background: #ef4444; color: #ffffff; text-align: center; margin-top: 8px;">
                    <i class="fa fa-arrow-right-from-bracket"></i> Logout
                </a>
            </div>

        </div>
        <!-- ===== END SIDEBAR ===== -->

        <!-- ===== CONTENT ===== -->
        <div class="admin-content">
            @RenderBody()
        </div>
        <!-- ===== END CONTENT ===== -->

    </div>

</body>
</html>