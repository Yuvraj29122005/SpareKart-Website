<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel – SpareKart</title>

    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Admin Layout CSS (in admin subfolder) -->
    <link rel="stylesheet" href="~/css/admin/adminLayout.css" />

</head>

<body>

    <div class="admin-main">

        <!-- ===== SIDEBAR ===== -->
        <div class="admin-sidebar">

            <h5 class="admin-logo">SpareKart</h5>
            <p class="admin-panel">Admin Panel</p>

            <a href="/Admin/Dashboard" class="active">
                <i class="fa fa-gauge-high"></i> Dashboard
            </a>
            <a href="/Admin/Products">
                <i class="fa fa-box"></i> Products
            </a>
            <a href="/Admin/AddProduct">
                <i class="fa fa-plus-circle"></i> Add Product
            </a>
            <a href="#">
                <i class="fa fa-shopping-bag"></i> Orders
            </a>
            <a href="#">
                <i class="fa fa-users"></i> Users
            </a>
            <a href="#">
                <i class="fa fa-comment-dots"></i> Feedback
            </a>

        </div>
        <!-- ===== END SIDEBAR ===== -->

        <!-- ===== CONTENT ===== -->
        <div class="admin-content">
            @RenderBody()
        </div>
        <!-- ===== END CONTENT ===== -->

    </div>

</body>
</html>