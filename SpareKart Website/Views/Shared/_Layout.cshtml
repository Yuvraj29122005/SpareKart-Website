<!DOCTYPE html>
<html>
<head>
    <title>SpareKart</title>
    <link rel="stylesheet" href="~/css/layout.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
</head>

<body>

    <!-- NAVBAR START -->

    <div class="navbar">

        <div class="nav-left">
            <img src="~/images/logo.png" class="logo" />
        </div>

        <div class="nav-center">
            <a href="/Home/Index" class="brand">SpareKart</a>
        </div>

        <div class="nav-right">
            <i class="fa fa-shopping-cart cart"></i>

            <div class="user">
                <i class="fa fa-user-circle"></i>
                <span>Hi,Yuvraj</span>
            </div>
        </div>

    </div>

    <!-- NAVBAR END -->
    @RenderBody()

    <!-- FOOTER START -->

    <div class="footer">

        <div class="footer-container">

            <div class="footer-box">
                <h3>About SpareKart</h3>
                <p>
                    Spare Kart is an online <br />
                    store providing quality <br />
                    car spare parts at <br />
                    affordable prices with <br />
                    fast, reliable service.
                </p>
            </div>

            <div class="footer-box">
                <h3>Quick Links</h3>
                <p>Home</p>
                <p>Products</p>
                <p>Orders</p>
            </div>

            <div class="footer-box">
                <h3>Support</h3>
                <p>Feedback</p>
                <p><i class="fa fa-envelope"></i> ydhadhal15@rku.ac.in</p>
                <p><i class="fa fa-phone"></i> +91 81403 51044</p>
            </div>

            <div class="footer-box">
                <h3>Follow Us</h3>
                <i class="fab fa-facebook icon"></i>
                <i class="fab fa-twitter icon"></i>
                <i class="fab fa-instagram icon"></i>
                <i class="fab fa-linkedin icon"></i>
            </div>

        </div>

        <hr />

        <p class="copyright">
            © 2026 <span>SpareKart</span> Car Parts. All rights reserved.
        </p>

    </div>

    <!-- FOOTER END -->

</body>
</html>