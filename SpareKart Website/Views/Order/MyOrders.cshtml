@model List<SpareKart_Website.Models.OrderModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/orders.css" />

<div class="orders-page">

    <!-- PAGE TITLE -->
    <div class="order-top-bar">
        <h2>My Orders</h2>
        @if (Model.Count > 0)
        {
            <a href="/Order/ClearHistory" class="clear-btn"
               onclick="return confirm('Clear all order history?')">
                Clear History
            </a>
        }
    </div>

    @* EMPTY STATE *@
    @if (Model.Count == 0)
    {
        <div class="empty-order">
            <div class="empty-box">
                <i class="fa fa-shopping-bag empty-icon"></i>
                <h3>No Orders Yet</h3>
                <p>You haven't placed any orders yet.</p>
                <a href="/Products/AllProducts">
                    <button class="shop-btn">Continue Shopping</button>
                </a>
            </div>
        </div>
    }

    @* ORDER CARDS *@
    else
    {
        @foreach (var order in Model)
        {
            <div class="order-card">

                <!-- TOP ROW: icon + order id + status badges -->
                <div class="oc-top">

                    <div class="oc-left">
                        <!-- Green circle checkmark icon -->
                        <div class="oc-check">
                            <i class="fa-solid fa-check"></i>
                        </div>

                        <div class="oc-id-block">
                            <span class="oc-label">Order ID</span>
                            <span class="oc-id">@order.OrderId</span>
                        </div>
                    </div>

                    <!-- Status badges — 2 pills like in the screenshot -->
                    <div class="oc-badges">
                        <span class="badge badge-delivered">Delivered</span>
                        <span class="badge badge-paid">Payment Completed</span>
                    </div>

                </div>

                <!-- META ROW: date | total | qty -->
                <div class="oc-meta">
                    <div class="oc-meta-item">
                        <i class="fa-regular fa-calendar"></i>
                        <span class="oc-meta-label">Order Date</span>
                        <span class="oc-meta-value">@order.Date</span>
                    </div>
                    <div class="oc-meta-item">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                        <span class="oc-meta-label">Total Amount</span>
                        <span class="oc-meta-value">&#8377;@order.TotalAmount</span>
                    </div>
                    <div class="oc-meta-item">
                        <i class="fa-solid fa-box"></i>
                        <span class="oc-meta-label">Items</span>
                        <span class="oc-meta-value">@order.Items.Count</span>
                    </div>
                </div>

                <!-- SHIPPING ADDRESS -->
                <div class="oc-address">
                    <i class="fa-solid fa-location-dot"></i>
                    <span>Shipping Address — @order.Address</span>
                </div>

                <!-- DIVIDER + VIEW ORDER DETAILS LINK -->
                <div class="oc-footer">
                    <a href="/Order/Details?id=@order.OrderId" class="oc-view-link">
                        View Order Details &rarr;
                    </a>
                </div>

            </div>
        }
    }

</div>