@model List<SpareKart_Website.Models.CartItem>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/cart.css" />

@* ========================================
   IF CART IS EMPTY
   ======================================== *@

@if (Model.Count == 0)
{
    <div class="empty-cart">

        <div class="empty-box">

            <!-- CART ICON -->
            <i class="fa fa-shopping-bag empty-icon"></i>

            <h3>Your Cart is Empty</h3>
            <p>Looks like you haven't added any items to your cart yet.</p>

            <!-- REDIRECT TO PRODUCTS PAGE -->
            <a href="/Products/AllProducts">
                <button>Continue Shopping</button>
            </a>

        </div>

    </div>
}

@* ========================================
   IF CART HAS PRODUCTS
   ======================================== *@

else
{
    <div class="cart-container">

        <h2 class="cart-title">Shopping Cart</h2>

        @* LOOP THROUGH CART ITEMS *@
        @foreach (var item in Model)
        {
            <div class="cart-item">

                <!-- PRODUCT IMAGE -->
                @{
                    var isFullUrl = item.Image != null && (item.Image.StartsWith("http") || item.Image.StartsWith("/"));
                }
                @if (isFullUrl)
                {
                    <img src="@item.Image" class="cart-img" alt="@item.Name" />
                }
                else
                {
                    <img src="~/images/@item.Image" class="cart-img" alt="@item.Name" />
                }

                <div class="cart-info">

                    <!-- PRODUCT NAME -->
                    <h4>@item.Name</h4>

                    <!-- PRODUCT PRICE -->
                    <p class="price">₹@item.Price</p>

                    <!-- QUANTITY BUTTONS -->
                    <div class="qty">

                        <!-- DECREASE QUANTITY -->
                        <a href="/Cart/Decrease?name=@item.Name"
                           class="qty-btn">-</a>

                        <!-- CURRENT QTY -->
                        <span>@item.Quantity</span>

                        <!-- INCREASE QUANTITY -->
                        @if (item.Quantity >= item.MaxStock)
                        {
                            <a href="#" class="qty-btn" onclick="alert('Maximum available stock for this item is @item.MaxStock!'); return false;" style="background-color: #e2e8f0; color: #94a3b8; cursor: not-allowed;">+</a>
                        }
                        else
                        {
                            <a href="/Cart/Increase?name=@Uri.EscapeDataString(item.Name)"
                               class="qty-btn">+</a>
                        }

                    </div>

                    <!-- REMOVE ITEM -->
                    <a href="/Cart/Remove?name=@item.Name"
                       class="remove-btn">
                        Remove
                    </a>

                </div>

                <!-- SUBTOTAL -->
                <div class="subtotal">
                    ₹@(item.Price* item.Quantity)
                </div>

            </div>
        }

        <!-- CART SUMMARY -->
        <div class="cart-summary">

            <!-- TOTAL AMOUNT -->
            <h3>
                Total:
                ₹@Model.Sum(x => x.Price * x.Quantity)
            </h3>

            @* ===========================================
               VERY IMPORTANT CHANGE
               ===========================================

               ❌ OLD CODE WAS:
               Sending name, price, image in URL

               /Checkout/Index?name=...&price=...&image=...

               THIS WAS CAUSING:
               CartController.cart COUNT = 0
               Order NOT SAVED
               Redirect to Home

               -------------------------------------------

               ✅ NOW:
               We are just going to Checkout
               and Checkout will read directly
               from CartController.cart list

               =========================================== *@

            <a href="/Checkout/Index">

                <button class="checkout-btn">
                    Proceed to Checkout
                </button>

            </a>

        </div>

    </div>
}