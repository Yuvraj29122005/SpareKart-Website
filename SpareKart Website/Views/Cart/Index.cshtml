@model List<SpareKart_Website.Models.CartItem>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/cart.css" />

@if (Model.Count == 0)
{
    <div class="empty">
        <h3>Your Cart is Empty</h3>
        <a href="/Products/AllProducts">
            <button>Continue Shopping</button>
        </a>
    </div>
}
else
{
    <div class="cart-container">

        @foreach (var item in Model)
        {
            <div class="cart-item">

                <img src="~/images/@item.Image" />

                <div class="info">
                    <h4>@item.Name</h4>
                    <p>₹@item.Price</p>

                    <div class="qty">
                        <a href="/Cart/Decrease?name=@item.Name">-</a>
                        <span>@item.Quantity</span>
                        <a href="/Cart/Increase?name=@item.Name">+</a>
                    </div>

                    <a href="/Cart/Remove?name=@item.Name" class="remove">Remove</a>

                </div>

            </div>
        }

        <h3>Total ₹@Model.Sum(x => x.Price * x.Quantity)</h3>

        <a href="/Checkout/Index?name=@Model[0].Name&price=@Model.Sum(x => x.Price * x.Quantity)&image=@Model[0].Image">
            <button>Checkout</button>
        </a>

    </div>
}