@model SpareKart_Website.Models.ForgotPasswordModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SpareKart - Forgot Password</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <!-- Shared Auth CSS + Forgot Password CSS -->
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="~/css/forgotpassword.css" />
</head>
<body>

    <div class="login-page">

        <!-- Forgot Password Card -->
        <div class="login-card">

            <!-- Logo -->
            <div class="login-logo">
                <img src="~/images/logo.png" alt="SpareKart Logo" />
            </div>

            <!-- Heading -->
            <h1 class="login-title">Password Reset</h1>
            <p class="login-subtitle">Enter your email to reset your password</p>

            <!-- Forgot Password Form -->
            <form method="post" class="login-form" novalidate>

                <!-- Email Field -->
                <div class="form-group">
                    <label for="email">Email</label>
                    <div class="input-wrapper">
                        <i class="fa-regular fa-envelope input-icon"></i>
                        <input
                            type="email"
                            id="email"
                            name="Email"
                            value="@Model?.Email"
                            placeholder="Enter your email"
                            required
                            autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="login-btn">
                    <span>Send Reset Link</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </button>

            </form>

            <!-- Divider -->
            <div class="login-divider">
                <span>or</span>
            </div>

            <!-- Back to Login Link -->
            <p class="register-text">
                Remember your password?
                <a href="/Account/Login" class="register-link">Back to Login</a>
            </p>

        </div>

    </div>

    <!-- Alert and redirect after successful submission -->
    @if (TempData["ForgotSuccess"] != null)
    {
        <script>
            alert("Password reset link has been sent to your email!");
            window.location.href = "/Account/Login";
        </script>
    }

</body>
</html>
