@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SpareKart - Verify OTP</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forgotpassword.css" asp-append-version="true" />
    <style>
        .validation-errors {
             color: #e74c3c;
             text-align: center;
             font-size: 0.9rem;
             margin-bottom: 1rem;
        }
    </style>
</head>
<body>

    <div class="login-page">
        <div class="login-card">
            <div class="login-logo">
                <img src="~/images/logo.png" alt="SpareKart Logo" asp-append-version="true" />
            </div>

            <h1 class="login-title">Verify Your Email</h1>
            <p class="login-subtitle">We have sent a 6-digit OTP to <strong>@ViewBag.Email</strong></p>

            <form method="post" action="/Account/VerifyOtp" class="login-form">

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="validation-errors">
                        @Html.ValidationSummary(true)
                    </div>
                }

                <input type="hidden" name="email" value="@ViewBag.Email" />

                <!-- OTP Field -->
                <div class="form-group">
                    <label for="otp">Enter OTP</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-key input-icon"></i>
                        <input
                            type="text"
                            id="otp"
                            name="otp"
                            placeholder="6-digit code"
                            required
                            maxlength="6" />
                    </div>
                </div>

                <button type="submit" class="login-btn">
                    <span>Verify Account</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </button>

            </form>

        </div>
    </div>

</body>
</html>
