@using SpareKart_Website.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cart = ViewBag.Cart as List<CartItem>;
    int total = ViewBag.Total;
}
<link rel="stylesheet" href="~/css/checkout.css" />

<h2 class="page-title">Checkout</h2>

<form id="checkoutForm" asp-controller="Checkout" asp-action="PlaceOrder" method="post" novalidate>
    <!-- Hidden fields for static Buy Now flow -->
    @if (!string.IsNullOrEmpty(ViewBag.BuyNowName))
    {
        <input type="hidden" name="buyNowName" value="@ViewBag.BuyNowName" />
        <input type="hidden" name="buyNowPrice" value="@ViewBag.BuyNowPrice" />
        <input type="hidden" name="buyNowImage" value="@ViewBag.BuyNowImage" />
        <input type="hidden" name="buyNowQty" value="@ViewBag.BuyNowQty" />
    }

    <div class="checkout">

        <!-- ====== LEFT: FORM SECTIONS ====== -->
        <div class="form">

            <!-- CONTACT INFORMATION -->
            <div class="form-box">
                <h4><i class="fa-regular fa-envelope"></i> Contact Information</h4>

                <label for="fullname">Full Name *</label>
                <input type="text" id="fullname" name="fullname" placeholder="Yuvraj Dhadhal" />
                <span class="field-error" id="err-fullname"></span>

                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="example@gmail.com" />
                <span class="field-error" id="err-email"></span>

                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" placeholder="+91 9099542131" />
                <span class="field-error" id="err-phone"></span>
            </div>

            <!-- SHIPPING ADDRESS -->
            <div class="form-box">
                <h4><i class="fa-solid fa-location-dot"></i> Shipping Address</h4>

                <label for="address">Complete Address *</label>
                <textarea id="address" name="address" rows="4" placeholder="House No., Street, City, State, PIN Code"></textarea>
                <span class="field-error" id="err-address"></span>
            </div>

            <!-- PAYMENT METHOD -->
            <div class="form-box">
                <h4><i class="fa-regular fa-credit-card"></i> Payment Method</h4>

                <!-- COD option — selected by default (highlighted blue) -->
                <label class="payment-option selected" id="label-cod">
                    <input type="radio" name="pay" value="COD" checked onchange="highlightPayment(this)" />
                    <div class="pay-info">
                        <span class="pay-title">Cash on Delivery</span>
                        <span class="pay-desc">Pay when you receive your order</span>
                    </div>
                </label>

                <!-- Online Payment -->
                <label class="payment-option" id="label-online">
                    <input type="radio" name="pay" value="Online" onchange="highlightPayment(this)" />
                    <div class="pay-info">
                        <span class="pay-title">Online Payment</span>
                        <span class="pay-desc">UPI, Credit/Debit Cards, Net Banking</span>
                    </div>
                </label>
            </div>

        </div>

        <!-- ====== RIGHT: ORDER SUMMARY ====== -->
        <div class="summary">

            <h3>Order Summary</h3>

            <div class="order-items">
                @foreach (var item in cart)
                {
                    <div class="order-card">
                        <img src="~/images/@item.Image" class="sum-img" alt="@item.Name" />
                        <div class="order-info">
                            <p class="item-name">@item.Name</p>
                            <p class="item-qty">Qty: @item.Quantity</p>
                            <p class="item-price">&#8377;@(item.Price * item.Quantity)</p>
                        </div>
                    </div>
                }
            </div>

            <hr class="summary-divider" />

            <div class="summary-row">
                <span>Subtotal</span>
                <span>&#8377;@total</span>
            </div>
            <div class="summary-row">
                <span>Shipping</span>
                <span class="free-text">Free</span>
            </div>

            <div class="total-row">
                <span>Total</span>
                <span>&#8377;@total</span>
            </div>

            <button type="submit" class="place-btn">Place Order</button>

        </div>

    </div>

</form>

<script>
    /* ====== Payment option highlight ====== */
    function highlightPayment(radio) {
        // Remove 'selected' class from all payment labels
        document.querySelectorAll('.payment-option').forEach(lbl => lbl.classList.remove('selected'));
        // Add to the clicked one
        radio.closest('.payment-option').classList.add('selected');
    }

    /* ====== Field-level validation ====== */
    function showError(inputId, errorId, message) {
        const input = document.getElementById(inputId);
        const err = document.getElementById(errorId);
        input.classList.add('input-error');
        err.textContent = message;
    }

    function clearError(inputId, errorId) {
        const input = document.getElementById(inputId);
        const err = document.getElementById(errorId);
        input.classList.remove('input-error');
        err.textContent = '';
    }

    /* Clear error as user types */
    ['fullname', 'email', 'phone', 'address'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.addEventListener('input', function () {
                const errId = 'err-' + id;
                if (el.value.trim() !== '') clearError(id, errId);
            });
        }
    });

    /* Validate on submit */
    document.getElementById('checkoutForm').addEventListener('submit', function (e) {
        let valid = true;

        /* Full Name */
        const name = document.getElementById('fullname').value.trim();
        if (name === '') {
            showError('fullname', 'err-fullname', 'Full name is required.');
            valid = false;
        } else {
            clearError('fullname', 'err-fullname');
        }

        /* Email */
        const email = document.getElementById('email').value.trim();
        const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        if (email === '') {
            showError('email', 'err-email', 'Email address is required.');
            valid = false;
        } else if (!emailRegex.test(email)) {
            showError('email', 'err-email', 'Please enter a valid email address.');
            valid = false;
        } else {
            clearError('email', 'err-email');
        }

        /* Phone */
        const phone = document.getElementById('phone').value.trim();
        const phoneRegex = /^[0-9]{10}$/;
        if (phone === '') {
            showError('phone', 'err-phone', 'Phone number is required.');
            valid = false;
        } else if (!phoneRegex.test(phone.replace(/\s|\+91/g, ''))) {
            showError('phone', 'err-phone', 'Enter a valid 10-digit phone number.');
            valid = false;
        } else {
            clearError('phone', 'err-phone');
        }

        /* Address */
        const address = document.getElementById('address').value.trim();
        if (address === '') {
            showError('address', 'err-address', 'Shipping address is required.');
            valid = false;
        } else if (address.length < 10) {
            showError('address', 'err-address', 'Please enter a complete address.');
            valid = false;
        } else {
            clearError('address', 'err-address');
        }

        if (!valid) e.preventDefault();
    });
</script>