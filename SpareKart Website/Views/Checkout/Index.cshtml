@using SpareKart_Website.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cart = ViewBag.Cart as List<CartItem>;
    int total = ViewBag.Total;
    string razorpayKey = ViewBag.RazorpayKeyId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/checkout.css" />
}

<h2 class="page-title">Checkout</h2>

<form id="checkoutForm" asp-controller="Checkout" asp-action="PlaceOrder" method="post" novalidate>
    <!-- Hidden fields for Buy Now flow -->
    @if (!string.IsNullOrEmpty(ViewBag.BuyNowName as string))
    {
        <input type="hidden" name="buyNowName" id="buyNowName" value="@ViewBag.BuyNowName" />
        <input type="hidden" name="buyNowPrice" id="buyNowPrice" value="@ViewBag.BuyNowPrice" />
        <input type="hidden" name="buyNowImage" id="buyNowImage" value="@ViewBag.BuyNowImage" />
        <input type="hidden" name="buyNowQty" id="buyNowQty" value="@ViewBag.BuyNowQty" />
    }

    <div class="checkout">

        <!-- ====== LEFT: FORM SECTIONS ====== -->
        <div class="form">

            <!-- CONTACT INFORMATION -->
            <div class="form-box">
                <h4><i class="fa-regular fa-envelope"></i> Contact Information</h4>

                <label for="fullname">Full Name *</label>
                <input type="text" id="fullname" name="fullname" placeholder="Yuvraj Dhadhal" />
                <span class="field-error" id="err-fullname"></span>

                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="example@gmail.com" />
                <span class="field-error" id="err-email"></span>

                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" placeholder="+91 9099542131" />
                <span class="field-error" id="err-phone"></span>
            </div>

            <!-- SHIPPING ADDRESS -->
            <div class="form-box">
                <h4><i class="fa-solid fa-location-dot"></i> Shipping Address</h4>

                <label for="address">Complete Address *</label>
                <textarea id="address" name="address" rows="4" placeholder="House No., Street, City, State, PIN Code"></textarea>
                <span class="field-error" id="err-address"></span>
            </div>

            <!-- PAYMENT METHOD -->
            <div class="form-box">
                <h4><i class="fa-regular fa-credit-card"></i> Payment Method</h4>

                <!-- COD option — selected by default -->
                <label class="payment-option selected" id="label-cod">
                    <input type="radio" name="pay" value="COD" checked onchange="highlightPayment(this)" />
                    <div class="pay-icon-wrap">
                        <i class="fa-solid fa-truck pay-icon"></i>
                    </div>
                    <div class="pay-info">
                        <span class="pay-title">Cash on Delivery</span>
                        <span class="pay-desc">Pay when you receive your order</span>
                    </div>
                </label>

                <!-- Online Payment -->
                <label class="payment-option" id="label-online">
                    <input type="radio" name="pay" value="Online" onchange="highlightPayment(this)" />
                    <div class="pay-icon-wrap online-icon">
                        <i class="fa-solid fa-shield-halved pay-icon"></i>
                    </div>
                    <div class="pay-info">
                        <span class="pay-title">Pay Online <span class="razorpay-badge">Razorpay</span></span>
                        <span class="pay-desc">UPI, Credit/Debit Cards, Net Banking, Wallets</span>
                    </div>
                </label>
            </div>

        </div>

        <!-- ====== RIGHT: ORDER SUMMARY ====== -->
        <div class="summary">

            <h3><i class="fa-solid fa-receipt"></i> Order Summary</h3>

            <div class="order-items">
                @foreach (var item in cart)
                {
                    var isFullUrl = item.Image != null && item.Image.StartsWith("http");
                    <div class="order-card">
                        @if (isFullUrl)
                        {
                            <img src="@item.Image" class="sum-img" alt="@item.Name" />
                        }
                        else
                        {
                            <img src="~/images/@item.Image" class="sum-img" alt="@item.Name" />
                        }
                        <div class="order-info">
                            <p class="item-name">@item.Name</p>
                            <p class="item-qty">Qty: @item.Quantity</p>
                            <p class="item-price">&#8377;@(item.Price * item.Quantity)</p>
                        </div>
                    </div>
                }
            </div>

            <hr class="summary-divider" />

            <div class="summary-row">
                <span>Subtotal</span>
                <span>&#8377;@total</span>
            </div>
            <div class="summary-row">
                <span>Shipping</span>
                <span class="free-text">Free</span>
            </div>

            <div class="total-row">
                <span>Total</span>
                <span id="totalAmount">&#8377;@total</span>
            </div>

            <button type="submit" class="place-btn" id="placeOrderBtn">
                <i class="fa-solid fa-lock"></i>
                <span id="btnText">Place Order</span>
            </button>

            <div class="secure-badge">
                <i class="fa-solid fa-shield-halved"></i> 100% Secure & Encrypted Payment
            </div>
        </div>

    </div>

</form>

<!-- Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    const TOTAL_AMOUNT = @total;
    const RAZORPAY_KEY = '@razorpayKey';

    /* ====== Payment option highlight ====== */
    function highlightPayment(radio) {
        document.querySelectorAll('.payment-option').forEach(lbl => lbl.classList.remove('selected'));
        radio.closest('.payment-option').classList.add('selected');

        // Update button text based on payment method
        const btnText = document.getElementById('btnText');
        if (radio.value === 'Online') {
            btnText.textContent = 'Pay Now ₹' + TOTAL_AMOUNT;
        } else {
            btnText.textContent = 'Place Order';
        }
    }

    /* ====== Field-level validation ====== */
    function showError(inputId, errorId, message) {
        const input = document.getElementById(inputId);
        const err = document.getElementById(errorId);
        input.classList.add('input-error');
        err.textContent = message;
    }

    function clearError(inputId, errorId) {
        const input = document.getElementById(inputId);
        const err = document.getElementById(errorId);
        input.classList.remove('input-error');
        err.textContent = '';
    }

    /* Clear error as user types */
    ['fullname', 'email', 'phone', 'address'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
            el.addEventListener('input', function () {
                const errId = 'err-' + id;
                if (el.value.trim() !== '') clearError(id, errId);
            });
        }
    });

    /* ====== Validate form fields ====== */
    function validateForm() {
        let valid = true;

        const name = document.getElementById('fullname').value.trim();
        if (name === '') {
            showError('fullname', 'err-fullname', 'Full name is required.');
            valid = false;
        } else {
            clearError('fullname', 'err-fullname');
        }

        const email = document.getElementById('email').value.trim();
        const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        if (email === '') {
            showError('email', 'err-email', 'Email address is required.');
            valid = false;
        } else if (!emailRegex.test(email)) {
            showError('email', 'err-email', 'Please enter a valid email address.');
            valid = false;
        } else {
            clearError('email', 'err-email');
        }

        const phone = document.getElementById('phone').value.trim();
        const phoneRegex = /^[0-9]{10}$/;
        if (phone === '') {
            showError('phone', 'err-phone', 'Phone number is required.');
            valid = false;
        } else if (!phoneRegex.test(phone.replace(/\s|\+91/g, ''))) {
            showError('phone', 'err-phone', 'Enter a valid 10-digit phone number.');
            valid = false;
        } else {
            clearError('phone', 'err-phone');
        }

        const address = document.getElementById('address').value.trim();
        if (address === '') {
            showError('address', 'err-address', 'Shipping address is required.');
            valid = false;
        } else if (address.length < 10) {
            showError('address', 'err-address', 'Please enter a complete address.');
            valid = false;
        } else {
            clearError('address', 'err-address');
        }

        return valid;
    }

    /* ====== Handle form submit ====== */
    document.getElementById('checkoutForm').addEventListener('submit', function (e) {
        if (!validateForm()) {
            e.preventDefault();
            return;
        }

        const paymentMethod = document.querySelector('input[name="pay"]:checked').value;

        // If Online Payment, prevent form submit and open Razorpay
        if (paymentMethod === 'Online') {
            e.preventDefault();
            initiateRazorpayPayment();
        }
        // else: COD — let form submit normally
    });

    /* ====== Razorpay Payment Flow ====== */
    async function initiateRazorpayPayment() {
        const btn = document.getElementById('placeOrderBtn');
        const btnText = document.getElementById('btnText');
        btn.disabled = true;
        btnText.textContent = 'Processing...';
        btn.classList.add('loading');

        try {
            // Step 1: Create Razorpay order on server
            const response = await fetch('/Checkout/CreateRazorpayOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount: TOTAL_AMOUNT })
            });

            const data = await response.json();

            if (!data.success) {
                alert('Error: ' + data.message);
                resetButton();
                return;
            }

            // Step 2: Open Razorpay checkout
            const options = {
                key: RAZORPAY_KEY,
                amount: data.amount,
                currency: data.currency,
                name: 'SpareKart',
                description: 'Purchase from SpareKart Car Parts',
                order_id: data.orderId,
                handler: function (response) {
                    // Step 3: Verify payment on server
                    verifyPayment(response);
                },
                prefill: {
                    name: document.getElementById('fullname').value,
                    email: document.getElementById('email').value,
                    contact: document.getElementById('phone').value
                },
                theme: {
                    color: '#2563eb'
                },
                modal: {
                    ondismiss: function () {
                        resetButton();
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.on('payment.failed', function (resp) {
                alert('Payment failed: ' + resp.error.description);
                resetButton();
            });
            rzp.open();

        } catch (error) {
            alert('Something went wrong. Please try again.');
            console.error(error);
            resetButton();
        }
    }

    /* ====== Verify and place order ====== */
    async function verifyPayment(razorpayResponse) {
        const btnText = document.getElementById('btnText');
        btnText.textContent = 'Verifying Payment...';

        const payload = {
            razorpayOrderId: razorpayResponse.razorpay_order_id,
            razorpayPaymentId: razorpayResponse.razorpay_payment_id,
            razorpaySignature: razorpayResponse.razorpay_signature,
            fullName: document.getElementById('fullname').value,
            email: document.getElementById('email').value,
            phone: document.getElementById('phone').value,
            address: document.getElementById('address').value
        };

        // Add Buy Now fields if present
        const buyNowName = document.getElementById('buyNowName');
        if (buyNowName) {
            payload.buyNowName = buyNowName.value;
            payload.buyNowPrice = parseInt(document.getElementById('buyNowPrice').value);
            payload.buyNowImage = document.getElementById('buyNowImage').value;
            payload.buyNowQty = parseInt(document.getElementById('buyNowQty').value);
        }

        try {
            const response = await fetch('/Checkout/VerifyPayment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await response.json();

            if (data.success) {
                // Redirect to order confirmation
                window.location.href = '/Checkout/OrderConfirmation?id=' + data.orderId;
            } else {
                alert('Payment verification failed: ' + data.message);
                resetButton();
            }
        } catch (error) {
            alert('Verification error. Please contact support.');
            console.error(error);
            resetButton();
        }
    }

    /* ====== Reset button state ====== */
    function resetButton() {
        const btn = document.getElementById('placeOrderBtn');
        const btnText = document.getElementById('btnText');
        btn.disabled = false;
        btn.classList.remove('loading');

        const paymentMethod = document.querySelector('input[name="pay"]:checked').value;
        if (paymentMethod === 'Online') {
            btnText.textContent = 'Pay Now ₹' + TOTAL_AMOUNT;
        } else {
            btnText.textContent = 'Place Order';
        }
    }
</script>