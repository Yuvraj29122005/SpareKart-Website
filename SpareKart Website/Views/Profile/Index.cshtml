@model SpareKart_Website.Models.User
@{
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
    ViewData["Title"] = "My Profile - SpareKart";
}

<div class="profile-page-wrapper">
    <h1 class="profile-heading">My Profile</h1>

    <div class="profile-grid">
        
        <!-- LEFT: User Card -->
        <div class="profile-left-card">
            <div class="avatar-container" style="overflow:hidden;">
                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                {
                    <img src="/@Model.ProfilePictureUrl" alt="Profile Picture" style="width: 100%; height: 100%; object-fit: cover;" />
                }
                else
                {
                    <i class="fa fa-user" id="avatarIcon"></i>
                }
            </div>

            <h2 id="displayName">@Model.Name</h2>
            <p class="email" id="displayEmail">@Model.Email</p>
            
            <div class="status-badge">Active Member</div>

            <div class="phone-row">
                <i class="fa fa-phone"></i>
                <span id="displayPhone">@(string.IsNullOrEmpty(Model.Phone) ? "No Phone Set" : Model.Phone)</span>
            </div>
            
            @if(Model.IsEmailVerified) {
                <div class="mt-3" style="color: #10b981; font-weight: bold; margin-top:10px;"><i class="fa fa-check-circle"></i> Email Verified</div>
            } else {
                <div class="mt-3" style="color: #ef4444; font-weight: bold; margin-top:10px;"><i class="fa fa-times-circle"></i> Email Not Verified</div>
            }
        </div>


        <!-- RIGHT: Personal Information Form -->
        <div class="profile-right-card">
            
            <div class="right-card-header">
                <h3>Personal Information</h3>
            </div>

            <form method="post" action="/Profile/UpdateProfile" id="profileForm" enctype="multipart/form-data">
                <div class="form-body">
                    
                    <!-- Profile Picture Upload (hidden until Edit) -->
                    <div class="form-group" id="fileUploadGroup" style="display: none;">
                        <label><i class="fa fa-camera"></i> Profile Picture</label>
                        <input type="file" name="profilePicture" id="profilePicture" accept="image/*" class="form-control" style="background:#fff; border: 1px solid #e2e8f0; padding: 10px; border-radius: 6px;" />
                    </div>

                    <!-- Name -->
                    <div class="form-group">
                        <label><i class="fa fa-user"></i> Full Name</label>
                        <input type="text" name="name" id="name" value="@Model.Name" required disabled />
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <label><i class="fa fa-envelope"></i> Email Address</label>
                        <input type="email" id="email" value="@Model.Email" class="locked" disabled title="Email address cannot be changed" />
                    </div>

                    <!-- Phone -->
                    <div class="form-group">
                        <label><i class="fa fa-phone"></i> Phone Number</label>
                        <input type="text" name="phone" id="phone" value="@Model.Phone" placeholder="Enter phone number" disabled />
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="save-btn-wrapper" style="display:flex; gap:15px; justify-content:center;">
                    <button type="button" id="editProfileBtn" class="save-btn" style="background-color: #3b82f6; display: inline-flex;" onclick="enableEditMode()">
                        <i class="fa fa-pencil"></i> Edit Profile
                    </button>
                    <button type="submit" id="saveChangesBtn" class="save-btn" style="display: none;">
                        <i class="fa fa-save"></i> Save Changes
                    </button>
                </div>
            </form>

            <script>
                function enableEditMode() {
                    // Enable inputs
                    document.getElementById('name').disabled = false;
                    document.getElementById('phone').disabled = false;
                    
                    // Show file upload element
                    document.getElementById('fileUploadGroup').style.display = 'block';

                    // Toggle buttons
                    document.getElementById('editProfileBtn').style.display = 'none';
                    document.getElementById('saveChangesBtn').style.display = 'inline-flex';
                }
            </script>

        </div>

    </div>
</div>