@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/products.css" />

<h2 class="p-title">Our Products</h2>

<div class="product-page">

    <!-- FILTER -->

    <div class="filter">
        <h4>Filters</h4>
        <input type="text" placeholder="Search products..." />
        <select>
            <option>All Categories</option>
        </select>
        <p>Price Range: ₹0 - ₹10000</p>
    </div>

    <!-- PRODUCTS -->

    <div class="product-list">

        <!-- PRODUCT 1 -->

        <div class="p-card">

            <a href="/Product/ProductDetails?name=Engine Oil Filter&price=499&image=engine.jpg">
                <img src="~/images/engine.jpg" />
                <h4>Engine Oil Filter</h4>
                <p class="desc">High-quality filter.</p>
            </a>

            <div class="bottom">
                <span>₹499</span>
                <a href="/Cart/Add?name=Engine Oil Filter&price=499&image=engine.jpg">
                    <button>Add</button>
                </a>
            </div>

        </div>

        <!-- PRODUCT 2 -->

        <div class="p-card">

            <a href="/Product/ProductDetails?name=Brake Disc Set&price=2999&image=brake.jpg">
                <img src="~/images/brake.jpg" />
                <h4>Brake Disc Set</h4>
                <p class="desc">Premium brake disc.</p>
            </a>

            <div class="bottom">
                <span>₹2999</span>
                <a href="/Cart/Add?name=Brake Disc Set&price=2999&image=brake.jpg">
                    <button>Add</button>
                </a>
            </div>

        </div>

        <!-- PRODUCT 3 -->

        <div class="p-card">

            <a href="/Product/ProductDetails?name=All Season Tyre&price=4500&image=tyre.jpg">
                <img src="~/images/tyre.jpg" />
                <h4>All Season Tyre</h4>
                <p class="desc">Durable tyre.</p>
            </a>

            <div class="bottom">
                <span>₹4500</span>
                <a href="/Cart/Add?name=All Season Tyre&price=4500&image=tyre.jpg">
                    <button>Add</button>
                </a>
            </div>

        </div>

        <!-- PRODUCT 4 -->

        <div class="p-card">

            <a href="/Product/ProductDetails?name=LED Headlight&price=1899&image=light.jpg">
                <img src="~/images/light.jpg" />
                <h4>LED Headlight</h4>
                <p class="desc">Bright LED headlight.</p>
            </a>

            <div class="bottom">
                <span>₹1899</span>
                <a href="/Cart/Add?name=LED Headlight&price=1899&image=light.jpg">
                    <button>Add</button>
                </a>
            </div>

        </div>

    </div>

</div>