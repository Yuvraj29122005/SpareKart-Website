@model SpareKartAdmin.Controllers.Product
@{
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<link rel="stylesheet" href="~/css/editProduct.css" />

<h4>Edit Product</h4>

<form method="post">
	<div class="edit-box">

		<input type="hidden" asp-for="Id" />

		<input asp-for="Name" class="form-control" />
		<input asp-for="Category" class="form-control mt-2" />
		<input asp-for="Price" class="form-control mt-2" />
		<input asp-for="Stock" class="form-control mt-2" />

		<button class="btn btn-primary mt-3">Update</button>
		<a href="/Product" class="btn btn-secondary mt-3">Cancel</a>

	</div>
</form>