@model SpareKart_Website.Models.Order
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Order Details";
}

<link rel="stylesheet" href="~/css/admin/adminOrderDetails.css" />

@if (Model == null)
{
    <h4 class="admin-page-title">Order Not Found</h4>
}
else
{
    <div>
        <h4 class="admin-page-title">
            Order #ORD-@Model.Id 
            @if (Model.PaymentStatus == "Completed")
            {
                <span class="badge-processing" style="background: #dcfce7; color: #166534;">Completed</span>
            }
            else
            {
                <span class="badge-processing" style="background: #fef08a; color: #854d0e;">Pending</span>
            }
        </h4>
        <p class="admin-page-sub">View and manage order information directly from DB</p>

        <div class="order-meta">
            <div><i class="fa-regular fa-calendar"></i> <span>@Model.OrderDate.ToString("MMM dd, yyyy")</span></div>
            <div><i class="fa-solid fa-credit-card"></i> Paid via <span>Online Checkout</span></div>
        </div>
    </div>

    <div class="order-details-grid">

        <!-- LEFT COLUMN - MAIN -->
        <div class="admin-card">
            <div class="order-items-list">
                @foreach (var item in Model.OrderItems)
                {
                    <div class="order-item">
                        <div class="item-info">
                            @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                            {
                                <img src="@item.Product.ImageUrl" class="item-img" alt="@item.Product.Name">
                            }
                            else
                            {
                                <img src="https://placehold.co/100x100?text=Item" class="item-img" alt="Item">
                            }
                            <div class="item-details">
                                <h6>@(item.Product?.Name ?? "Deleted Product")</h6>
                                <p>Quantity: @item.Quantity</p>
                            </div>
                        </div>
                        <div class="item-price">₹@item.UnitPrice</div>
                    </div>
                }
            </div>

            <div class="order-summary">
                <div class="summary-row total">
                    <span>Total Paid</span>
                    <span>₹@Model.TotalAmount</span>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN - SIDEBAR -->
        <div class="sidebar-cards">
            <div class="admin-card mb-4" style="margin-bottom: 24px;">
                <div class="card-title">
                    <i class="fa-solid fa-cube"></i> Customer Details
                </div>
                
                <div class="customer-info-row">
                    <div class="avatar">G</div>
                    <div>
                        <div class="customer-name">Guest Customer</div>
                        <div class="customer-sub">Ordered via guest checkout</div>
                    </div>
                </div>
            </div>

            <div class="admin-card">
                <div class="card-title">
                    <i class="fa-solid fa-location-dot" style="color: #f97316;"></i> Shipping Address
                </div>
                <div class="address-text">
                    <div>@Model.ShippingAddress</div>
                </div>
            </div>
        </div>

    </div>
}
