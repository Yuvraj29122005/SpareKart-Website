@model IEnumerable<SpareKart_Website.Models.Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Manage Products";
}

<link rel="stylesheet" href="~/css/admin/adminProducts.css" />

<!-- ==================== LIST VIEW ==================== -->
<div class="products-top-bar">
    <div>
        <h4 class="admin-page-title">Manage Products</h4>
        <p class="admin-page-sub">View and update your real SQL store inventory.</p>
    </div>
    <div class="d-flex gap-3">
        <div class="search-container">
            <i class="fa fa-search"></i>
            <input type="text" class="search-input" placeholder="Search products..." id="searchInput" onkeyup="filterTable()" />
        </div>
        <a href="/Admin/AddProduct" class="btn-add-product">
            <i class="fa fa-plus"></i> Add Product
        </a>
    </div>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width: 80px;">Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th style="width: 100px;">Actions</th>
            </tr>
        </thead>
        <tbody id="productsTableBody">
            @if(Model != null && Model.Any())
            {
                foreach(var p in Model)
                {
                    <tr>
                        <td>
                            @if(!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" class="product-img" alt="img" />
                            }
                            else
                            {
                                <img src="https://placehold.co/100x100?text=Part" class="product-img" alt="img" />
                            }
                        </td>
                        <td class="product-name-row"><strong>@p.Name</strong></td>
                        <td><span class="badge-category">@p.Category</span></td>
                        <td>₹@p.Price</td>
                        <td><span class="badge-stock">@(string.IsNullOrEmpty(p.Description) ? "0" : p.Description)</span></td>
                        <td>
                            <div class="action-icons">
                                <a href="/Admin/EditProduct/@p.Id" class="btn-icon btn-edit"><i class="fa fa-edit"></i></a>
                                <form action="/Admin/DeleteProduct" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button type="submit" class="btn-icon btn-delete" onclick="return confirm('Delete this product?')"><i class="fa fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No products exist in database.</td></tr>
            }
        </tbody>
    </table>
</div>

<script>
    function filterTable() {
        var input, filter, table, tr, td, i, txtValue;
        input = document.getElementById("searchInput");
        filter = input.value.toUpperCase();
        table = document.getElementById("productsTableBody");
        tr = table.getElementsByTagName("tr");
        for (i = 0; i < tr.length; i++) {
            td = tr[i].getElementsByClassName("product-name-row")[0];
            if (td) {
                txtValue = td.textContent || td.innerText;
                if (txtValue.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }       
        }
    }
</script>
