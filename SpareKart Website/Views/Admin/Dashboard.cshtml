@{
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/adminDashboard.css" />

<h4>Dashboard</h4>
<p>Welcome back! Here's what's happening with your store today.</p>

<div class="row mt-4">

	<div class="col-md-3">
		<div class="admin-card">
			<p>Total Products</p>
			<h4>8</h4>
			<small>Low stock</small>
		</div>
	</div>

	<div class="col-md-3">
		<div class="admin-card">
			<p>Total Orders</p>
			<h4>2</h4>
			<small>1 completed</small>
		</div>
	</div>

	<div class="col-md-3">
		<div class="admin-card">
			<p>Total Users</p>
			<h4>2</h4>
			<small>2 active</small>
		</div>
	</div>

	<div class="col-md-3">
		<div class="admin-card">
			<p>Total Revenue</p>
			<h4>₹5498</h4>
			<small>From completed orders</small>
		</div>
	</div>

</div>

<div class="row mt-4">

	<div class="col-md-8">
		<div class="admin-lowstock">
			All products well stocked
		</div>
	</div>

	<div class="col-md-4">

		<div class="admin-sidebox">
			<h6>Order Status</h6>
			<p style="color:green;">Completed - 1</p>
			<p style="color:orange;">Pending - 1</p>
			<p style="color:red;">Failed - 0</p>
		</div>

		<div class="admin-sidebox">
			<h6>Products by Category</h6>
			<p>Engine - 2</p>
			<p>Brakes - 2</p>
			<p>Tyres - 1</p>
			<p>Lights - 2</p>
			<p>Accessories - 1</p>
		</div>

	</div>

</div>