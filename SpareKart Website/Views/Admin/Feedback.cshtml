@model IEnumerable<SpareKart_Website.Models.Feedback>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "User Feedback";
    int lastWeekCount = Model.Count(f => f.DateSubmitted >= DateTime.Now.AddDays(-7));
}

<link rel="stylesheet" href="~/css/admin/adminFeedback.css" />

<h4 class="admin-page-title">User Feedback</h4>

<!-- KPI CARDS -->
<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-title">Total Feedback</div>
        <div class="kpi-value" id="kpiTotal">@Model.Count()</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">This Week</div>
        <div class="kpi-value blue" id="kpiWeek">@lastWeekCount</div>
    </div>
</div>

<!-- SEARCH -->
<div class="search-container">
    <i class="fa fa-search"></i>
    <input type="text" class="search-input" id="searchInput" placeholder="Search feedback by name, email or message..." onkeyup="filterFeedback()" />
</div>

<!-- FEEDBACK GRID -->
<div class="feedback-grid" id="feedbackContainer">
    @if (Model.Any())
    {
        int index = 0;
        foreach(var f in Model)
        {
            var colors = new[] { "orange", "blue", "green", "purple" };
            var color = colors[index % colors.Length];
            index++;
            
            <div class="feedback-card" data-search="@Html.Raw($"{f.Name} {f.Email} {f.Message}".ToLower())">
                <div class="fb-header">
                    <div class="fb-avatar @color">
                        <i class="fa-regular fa-user"></i>
                    </div>
                    <div class="fb-user-info">
                        <div class="fb-name">@f.Name</div>
                        <div class="fb-email"><i class="fa-regular fa-envelope"></i> @f.Email</div>
                        <div class="fb-date"><i class="fa-regular fa-calendar"></i> @f.DateSubmitted.ToString("yyyy-MM-dd")</div>
                    </div>
                </div>
                <div class="fb-content-box">
                    <div class="fb-label">
                        <i class="fa-regular fa-message"></i> Feedback
                    </div>
                    @f.Message
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-muted p-4 w-100 text-center">No feedback found in the database.</div>
    }
</div>

<script>
    function filterFeedback() {
        const text = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('.feedback-card');
        
        cards.forEach(card => {
            const searchText = card.getAttribute('data-search');
            if (searchText.includes(text)) {
                card.style.display = 'flex'; // Assuming flex layout based on default styles
            } else {
                card.style.display = 'none';
            }
        });
    }
</script>
