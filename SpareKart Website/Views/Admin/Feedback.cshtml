@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "User Feedback";
}

<link rel="stylesheet" href="~/css/admin/adminFeedback.css" />

<h4 class="admin-page-title">User Feedback</h4>

<!-- KPI CARDS -->
<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-title">Total Feedback</div>
        <div class="kpi-value" id="kpiTotal">0</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">This Week</div>
        <div class="kpi-value blue" id="kpiWeek">0</div>
    </div>
</div>

<!-- SEARCH -->
<div class="search-container">
    <i class="fa fa-search"></i>
    <input type="text" class="search-input" id="searchInput" placeholder="Search feedback by name, email or message..." onkeyup="filterFeedback()" />
</div>

<!-- FEEDBACK GRID -->
<div class="feedback-grid" id="feedbackContainer">
    <!-- Populated by JS -->
</div>

<script>
    // Initial dummy data for feedback
    function initFeedback() {
        let stored = localStorage.getItem('sparekart_feedback_data');
        if (stored) {
            return JSON.parse(stored);
        } else {
            let initial = [
                { id: "F001", name: "Alice Johnson", email: "alice@example.com", date: "2026-01-25", message: "Great service! Products arrived on time and in perfect condition.", avatarColor: "orange" },
                { id: "F002", name: "Bob Wilson", email: "bob@example.com", date: "2026-01-27", message: "Good quality parts at reasonable prices. Will order again.", avatarColor: "blue" }
            ];
            localStorage.setItem('sparekart_feedback_data', JSON.stringify(initial));
            return initial;
        }
    }

    let feedbacks = initFeedback();

    function updateKPIs() {
        document.getElementById('kpiTotal').innerText = feedbacks.length;
        
        // Simulating "This Week" count - just using a dummy variable or filtering by recent dates.
        // For simplicity hitting the screenshot exactly, setting to 0 for dummy data.
        document.getElementById('kpiWeek').innerText = "0";
    }

    function renderFeedback(filterText = '') {
        const container = document.getElementById('feedbackContainer');
        container.innerHTML = '';

        const lowerFilter = filterText.toLowerCase();
        let renderedCount = 0;

        feedbacks.forEach(f => {
            if (filterText && !f.name.toLowerCase().includes(lowerFilter) && !f.email.toLowerCase().includes(lowerFilter) && !f.message.toLowerCase().includes(lowerFilter)) {
                return;
            }

            renderedCount++;
            const card = document.createElement('div');
            card.className = 'feedback-card';
            card.innerHTML = `
                <div class="fb-header">
                    <div class="fb-avatar ${f.avatarColor}">
                        <i class="fa-regular fa-user"></i>
                    </div>
                    <div class="fb-user-info">
                        <div class="fb-name">${f.name}</div>
                        <div class="fb-email"><i class="fa-regular fa-envelope"></i> ${f.email}</div>
                        <div class="fb-date"><i class="fa-regular fa-calendar"></i> ${f.date}</div>
                    </div>
                </div>
                <div class="fb-content-box">
                    <div class="fb-label">
                        <i class="fa-regular fa-message"></i> Feedback
                    </div>
                    ${f.message}
                </div>
            `;
            container.appendChild(card);
        });

        if (renderedCount === 0) {
            container.innerHTML = `<div class="text-muted p-4">No feedback found.</div>`;
        }

        updateKPIs();
    }

    function filterFeedback() {
        const text = document.getElementById('searchInput').value;
        renderFeedback(text);
    }

    // Initialize display
    renderFeedback();
</script>
