@model SpareKart_Website.Models.User
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Admin Profile";
}

<link rel="stylesheet" href="~/css/admin/adminProfile.css" />

<h4 class="admin-page-title">Admin Profile</h4>

<div class="profile-container">
    
    <!-- LEFT CARD: AVATAR & BASIC DETAILS -->
    <div class="profile-card-left">
        <div class="avatar-wrapper">
            <div class="avatar-circle" id="avatarCircle">
                @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                {
                    <img src="/@Model.ProfilePictureUrl" alt="Avatar" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                }
                else
                {
                    <i class="fa-regular fa-user" id="avatarIcon"></i>
                }
            </div>
            <div class="btn-upload-avatar edit-mode d-none" onclick="document.getElementById('photoInput').click()" title="Change photo">
                <i class="fa-solid fa-camera"></i>
            </div>
        </div>
        <div class="profile-name">@Model.Name</div>
        <div class="profile-email">@Model.Email</div>
        <div class="badge-role">Administrator</div>
    </div>

    <!-- RIGHT CARD: INFORMATION FORM -->
    <div class="profile-card-right">
        <div class="card-header-flex">
            <div class="card-title">Personal Information</div>
            <button class="btn-edit-outline" id="btnToggleEdit" onclick="toggleEditMode()">
                <i class="fa-solid fa-pen"></i> Edit Profile
            </button>
        </div>

        <form action="/Admin/UpdateProfile" method="post" enctype="multipart/form-data">

            <!-- Hidden photo input -->
            <input type="file" name="profilePicture" id="photoInput" accept="image/*" style="display:none;" />

            <!-- FULL NAME -->
            <div class="info-group">
                <div class="info-label"><i class="fa-regular fa-user"></i> Full Name</div>
                <div class="info-value view-mode">@Model.Name</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-regular fa-user"></i>
                        <input type="text" name="name" class="form-input-iconed" value="@Model.Name" required />
                    </div>
                </div>
            </div>

            <!-- EMAIL ADDRESS (read-only) -->
            <div class="info-group">
                <div class="info-label"><i class="fa-regular fa-envelope"></i> Email Address <span style="font-size:11px; color:#94a3b8; margin-left:6px;">(cannot be changed)</span></div>
                <div class="info-value">@Model.Email</div>
            </div>

            <!-- PHONE NUMBER -->
            <div class="info-group">
                <div class="info-label"><i class="fa-solid fa-phone" style="font-size:11px;"></i> Phone Number</div>
                <div class="info-value view-mode">@(string.IsNullOrEmpty(Model.Phone) ? "Not Set" : Model.Phone)</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-solid fa-phone" style="font-size:11px;"></i>
                        <input type="text" name="phone" class="form-input-iconed" value="@Model.Phone" placeholder="+91 00000 00000" />
                    </div>
                </div>
            </div>

            <!-- ADDRESS -->
            <div class="info-group">
                <div class="info-label"><i class="fa-solid fa-location-dot"></i> Address</div>
                <div class="info-value view-mode">@(string.IsNullOrEmpty(Model.Address) ? "Not Set" : Model.Address)</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-solid fa-location-dot" style="top:20px;"></i>
                        <textarea name="address" class="form-input-iconed" rows="3" placeholder="Enter full address">@Model.Address</textarea>
                    </div>
                </div>
            </div>

            <!-- SAVE BUTTON -->
            <div class="action-row edit-mode d-none" style="display:flex; gap:10px;">
                <button type="submit" class="btn-save-primary" id="btnSave">Save Changes</button>
                <button type="button" class="btn-edit-outline" style="border-color:#e2e8f0; color:#64748b;" onclick="window.location.reload()">Cancel</button>
            </div>

        </form>
    </div>

</div>

<script>
    function toggleEditMode() {
        const views = document.querySelectorAll('.view-mode');
        const edits = document.querySelectorAll('.edit-mode');
        const btnTog = document.getElementById('btnToggleEdit');

        views.forEach(el => el.classList.add('d-none'));
        edits.forEach(el => el.classList.remove('d-none'));
        btnTog.classList.add('d-none');
    }
</script>
