@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Admin Profile";
}

<link rel="stylesheet" href="~/css/admin/adminProfile.css" />

<h4 class="admin-page-title">Admin Profile</h4>

<div class="profile-container">
    
    <!-- LEFT CARD: AVATAR & BASIC DETAILS -->
    <div class="profile-card-left">
        <div class="avatar-wrapper">
            <div class="avatar-circle" id="avatarCircle">
                <i class="fa-regular fa-user" id="avatarIcon"></i>
            </div>
            <!-- Hidden file input triggered by camera button -->
            <input type="file" id="photoInput" accept="image/*" style="display:none;" onchange="handlePhotoUpload(event)" />
            <div class="btn-upload-avatar" onclick="document.getElementById('photoInput').click()" title="Change photo">
                <i class="fa-solid fa-camera"></i>
            </div>
        </div>
        <div class="profile-name" id="displayTitleName">Admin</div>
        <div class="profile-email" id="displayTitleEmail">admin@carparts.com</div>
        <div class="badge-role">Administrator</div>
    </div>

    <!-- RIGHT CARD: INFORMATION FORM -->
    <div class="profile-card-right">
        <div class="card-header-flex">
            <div class="card-title">Personal Information</div>
            <button class="btn-edit-outline" id="btnToggleEdit" onclick="toggleEditMode()">
                <i class="fa-solid fa-pen"></i> Edit Profile
            </button>
        </div>

        <form id="profileForm" onsubmit="saveProfile(event)">

            <!-- FULL NAME -->
            <div class="info-group">
                <div class="info-label"><i class="fa-regular fa-user"></i> Full Name</div>
                <div class="info-value view-mode" id="viewName">Admin</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-regular fa-user"></i>
                        <input type="text" class="form-input-iconed" id="inputName" value="Admin" required />
                    </div>
                </div>
            </div>

            <!-- EMAIL ADDRESS (read-only, cannot be changed) -->
            <div class="info-group">
                <div class="info-label"><i class="fa-regular fa-envelope"></i> Email Address <span style="font-size:11px; color:#94a3b8; margin-left:6px;">(cannot be changed)</span></div>
                <div class="info-value" id="viewEmail">admin@carparts.com</div>
            </div>

            <!-- PHONE NUMBER -->
            <div class="info-group">
                <div class="info-label"><i class="fa-solid fa-phone" style="font-size:11px;"></i> Phone Number</div>
                <div class="info-value view-mode" id="viewPhone">+91 9876543210</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-solid fa-phone" style="font-size:11px;"></i>
                        <input type="text" class="form-input-iconed" id="inputPhone" value="+91 9876543210" required />
                    </div>
                </div>
            </div>

            <!-- ADDRESS -->
            <div class="info-group">
                <div class="info-label"><i class="fa-solid fa-location-dot"></i> Address</div>
                <div class="info-value view-mode" id="viewAddress">rk university, rajkot, gujarat, 380020</div>
                <div class="edit-mode d-none">
                    <div class="form-input-wrapper">
                        <i class="fa-solid fa-location-dot" style="top:20px;"></i>
                        <textarea class="form-input-iconed" id="inputAddress" rows="3" required>rk university, rajkot, gujarat, 380020</textarea>
                    </div>
                </div>
            </div>

            <!-- SAVE BUTTON -->
            <button type="submit" class="btn-save-primary edit-mode d-none" id="btnSave">Save Changes</button>

        </form>
    </div>

</div>

<script>
    let isEditMode = false;

    // Apply a data object directly to the DOM
    function applyProfileData(data) {
        document.getElementById('viewName').innerText    = data.name    || 'Admin';
        document.getElementById('viewEmail').innerText   = data.email   || 'admin@carparts.com';
        document.getElementById('viewPhone').innerText   = data.phone   || '+91 9876543210';
        document.getElementById('viewAddress').innerText = data.address || 'rk university, rajkot, gujarat, 380020';

        document.getElementById('displayTitleName').innerText  = data.name  || 'Admin';
        document.getElementById('displayTitleEmail').innerText = data.email || 'admin@carparts.com';

        document.getElementById('inputName').value    = data.name    || 'Admin';
        document.getElementById('inputEmail').value   = data.email   || 'admin@carparts.com';
        document.getElementById('inputPhone').value   = data.phone   || '+91 9876543210';
        document.getElementById('inputAddress').value = data.address || 'rk university, rajkot, gujarat, 380020';

        if (data.photo) applyPhoto(data.photo);
    }

    function applyPhoto(base64) {
        const circle = document.getElementById('avatarCircle');
        const icon   = document.getElementById('avatarIcon');
        circle.style.background = `url('${base64}') center / cover no-repeat`;
        if (icon) icon.style.display = 'none';
    }

    function loadProfileData() {
        const stored = localStorage.getItem('sparekart_admin_profile');
        if (stored) applyProfileData(JSON.parse(stored));
    }
    loadProfileData();

    function handlePhotoUpload(event) {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            const base64 = e.target.result;
            applyPhoto(base64);
            // Persist photo
            const stored = localStorage.getItem('sparekart_admin_profile');
            const data = stored ? JSON.parse(stored) : {};
            data.photo = base64;
            localStorage.setItem('sparekart_admin_profile', JSON.stringify(data));
        };
        reader.readAsDataURL(file);
    }

    function toggleEditMode() {
        isEditMode = !isEditMode;
        const views  = document.querySelectorAll('.view-mode');
        const edits  = document.querySelectorAll('.edit-mode');
        const btnTog = document.getElementById('btnToggleEdit');

        if (isEditMode) {
            views.forEach(el  => el.classList.add('d-none'));
            edits.forEach(el  => el.classList.remove('d-none'));
            btnTog.classList.add('d-none');
        } else {
            loadProfileData(); // cancel — revert to saved data
            views.forEach(el  => el.classList.remove('d-none'));
            edits.forEach(el  => el.classList.add('d-none'));
            btnTog.classList.remove('d-none');
        }
    }

    function saveProfile(e) {
        e.preventDefault();

        // Capture inputs FIRST before any DOM refresh
        const newProfile = {
            name:    document.getElementById('inputName').value.trim(),
            email:   document.getElementById('inputEmail').value.trim(),
            phone:   document.getElementById('inputPhone').value.trim(),
            address: document.getElementById('inputAddress').value.trim()
        };

        // Preserve existing photo
        const stored = localStorage.getItem('sparekart_admin_profile');
        if (stored) {
            const existing = JSON.parse(stored);
            if (existing.photo) newProfile.photo = existing.photo;
        }

        localStorage.setItem('sparekart_admin_profile', JSON.stringify(newProfile));

        // Apply directly — do NOT call loadProfileData first (avoids overwriting new values with old ones)
        applyProfileData(newProfile);

        isEditMode = false;
        document.querySelectorAll('.view-mode').forEach(el => el.classList.remove('d-none'));
        document.querySelectorAll('.edit-mode').forEach(el => el.classList.add('d-none'));
        document.getElementById('btnToggleEdit').classList.remove('d-none');

        alert('Profile updated successfully!');
    }
</script>
