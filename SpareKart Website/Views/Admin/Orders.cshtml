@model IEnumerable<SpareKart_Website.Models.Order>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Manage Orders";
}
<link rel="stylesheet" href="~/css/admin/adminOrders.css" />

<h4 class="admin-page-title">Manage Orders (SQL Database)</h4>

<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-title">Total Orders</div>
        <div class="kpi-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">Completed</div>
        <div class="kpi-value kpi-completed">@(Model?.Count(o => o.PaymentStatus == "Completed") ?? 0)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">Pending</div>
        <div class="kpi-value kpi-pending">@(Model?.Count(o => o.PaymentStatus != "Completed") ?? 0)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">Total Revenue (Completed)</div>
        <div class="kpi-value kpi-revenue">₹@(Model?.Where(o => o.PaymentStatus == "Completed").Sum(o => o.TotalAmount) ?? 0)</div>
    </div>
</div>

<div class="table-container">
    <table class="orders-table">
        <thead>
            <tr>
                <th>Order ID</th>
                <th>Address</th>
                <th>Items (Count)</th>
                <th>Total</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any())
            {
                foreach(var o in Model)
                {
                    <tr>
                        <td><a href="/Admin/OrderDetails/@o.Id" class="order-link">ORD-@o.Id</a></td>
                        <td>@o.ShippingAddress</td>
                        <td>@(o.OrderItems?.Sum(i => i.Quantity) ?? 0) item(s)</td>
                        <td>₹@o.TotalAmount</td>
                        <td>
                            @if(o.PaymentStatus == "Completed"){ <span class="badge-status status-completed">Completed</span> }
                            else { <span class="badge-status status-pending">Pending</span> }
                        </td>
                        <td>
                            <button class="btn-icon" onclick="window.location.href='/Admin/OrderDetails/@o.Id'">
                                <i class="fa fa-eye"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No orders currently stored in the database.</td></tr>
            }
        </tbody>
    </table>
</div>
