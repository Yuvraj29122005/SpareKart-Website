@model SpareKart_Website.Models.Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Add Product";
}

<link rel="stylesheet" href="~/css/admin/adminProducts.css" />

<div class="mb-4">
    <h4 class="admin-page-title">Add New Product</h4>
    <p class="admin-page-sub">Fill in the details to add a new spare part to your SQL database</p>
</div>

<div class="admin-form-card">
    <form method="post" action="/Admin/AddProduct" enctype="multipart/form-data">
        
        <div class="form-group">
            <label class="form-label"><i class="fa fa-cube"></i> Product Name *</label>
            <input type="text" class="form-control" name="Name" placeholder="e.g., Engine Oil Filter" required />
        </div>

        <div class="form-group">
            <label class="form-label"><i class="fa fa-tag"></i> Category *</label>
            <select class="form-select" name="Category" required>
                <option value="Engine">Engine</option>
                <option value="Brakes">Brakes</option>
                <option value="Tyres">Tyres</option>
                <option value="Lights">Lights</option>
                <option value="Accessories">Accessories</option>
            </select>
        </div>

        <div class="row-split">
            <div class="form-group">
                <label class="form-label"><i class="fa fa-dollar-sign"></i> Price (₹) *</label>
                <input type="number" step="0.01" class="form-control" name="Price" placeholder="0.00" required />
            </div>
            <div class="form-group">
                <label class="form-label"><i class="fa fa-boxes-stacked"></i> Stock Quantity *</label>
                <input type="number" class="form-control" name="StockQty" placeholder="10" required />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label"><i class="fa fa-file-lines"></i> Description</label>
            <textarea class="form-control" name="Description" placeholder="Product description..."></textarea>
        </div>

        <div class="form-group">
            <label class="form-label"><i class="fa fa-image"></i> Product Image</label>
            <input type="file" class="form-control" name="productImage" id="productImageInput" accept="image/*" onchange="previewImage(event)" />
            <span class="form-help">Select an image from your device for this product.</span>
            
            <div style="margin-top: 15px;">
                <img id="imagePreview" src="" alt="Preview" style="display:none; max-width: 150px; border-radius: 6px; border: 1px solid #e2e8f0; padding: 4px;" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Add Product</button>
            <a href="/Admin/Products" class="btn-cancel text-center text-decoration-none d-flex align-items-center justify-content-center">Cancel</a>
        </div>

    </form>
</div>

<script>
    function previewImage(event) {
        var file = event.target.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function (e) {
                var preview = document.getElementById('imagePreview');
                preview.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(file);
        }
    }
</script>
