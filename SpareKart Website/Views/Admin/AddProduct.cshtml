@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Add Product";
}

<link rel="stylesheet" href="~/css/admin/adminDashboard.css" />

<h4 class="admin-page-title">Add Product</h4>
<p class="admin-page-sub">Fill in the details to add a new product to the store.</p>

<div class="admin-sidebox" style="max-width:600px;">

    <div class="mb-3">
        <label class="form-label fw-semibold">Product Name</label>
        <input type="text" class="form-control" placeholder="e.g. Brake Pad Set" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Category</label>
        <select class="form-select">
            <option>Engine</option>
            <option>Brakes</option>
            <option>Tyres</option>
            <option>Lights</option>
            <option>Accessories</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Price (₹)</label>
        <input type="number" class="form-control" placeholder="0.00" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Stock Quantity</label>
        <input type="number" class="form-control" placeholder="0" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Description</label>
        <textarea class="form-control" rows="3" placeholder="Product description..."></textarea>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary"><i class="fa fa-save"></i> Save Product</button>
        <a href="/Admin/Products" class="btn btn-outline-secondary">Cancel</a>
    </div>

</div>
