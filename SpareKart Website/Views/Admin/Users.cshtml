@model IEnumerable<SpareKart_Website.Models.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Manage Users";
}
<link rel="stylesheet" href="~/css/admin/adminUsers.css" />

<h4 class="admin-page-title">Manage SQL Database Users</h4>

<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-title">Total Registered</div>
        <div class="kpi-value">@(Model?.Count() ?? 0)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">Email Verified</div>
        <div class="kpi-value kpi-active">@(Model?.Count(u => u.IsEmailVerified) ?? 0)</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-title">Unverified</div>
        <div class="kpi-value kpi-blocked">@(Model?.Count(u => !u.IsEmailVerified) ?? 0)</div>
    </div>
</div>

<div class="table-container">
    <table class="users-table">
        <thead>
            <tr>
                <th>User</th>
                <th>Contact</th>
                <th>Verified</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any())
            {
                foreach(var u in Model)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar"><i class="fa-regular fa-user"></i></div>
                                <div class="user-name">@u.Name</div>
                            </div>
                        </td>
                        <td>
                            <div class="user-contact">
                                <div><i class="fa-regular fa-envelope"></i> @u.Email</div>
                                <div><i class="fa-solid fa-phone"></i> @u.Phone</div>
                            </div>
                        </td>
                        <td>
                            @if(u.IsEmailVerified)
                            {
                                <span class="badge-status status-active">Yes</span>
                            }
                            else
                            {
                                <span class="badge-status status-blocked">No</span>
                            }
                        </td>
                        <td>
                            <form action="/Admin/RemoveUser" method="post">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit" class="btn-action-outline" style="color: #ef4444; border-color: #fee2e2;" onclick="return confirm('Remove user @u.Name forever?')">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center text-muted py-4">No users in database.</td></tr>
            }
        </tbody>
    </table>
</div>
