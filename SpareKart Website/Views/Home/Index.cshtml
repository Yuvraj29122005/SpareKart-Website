@model IEnumerable<SpareKart_Website.Models.Product>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home - SpareKart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- HERO SECTION -->
<div class="hero">
    <img src="/images/home.png" alt="SpareKart Banner" class="hero-img" />
</div>

<!-- FEATURED PRODUCTS -->
<section class="products-section">
    <h2 class="section-title">Featured Products</h2>

    <div class="products-grid">
        @if (Model != null && Model.Any())
        {
            foreach(var p in Model)
            {
                <a href="/Products/ProductDetails/@p.Id" class="product-link">
                    <div class="product-card">
                        <img src="@(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "https://placehold.co/200x200?text=Product")" alt="@p.Name" class="product-img" />
                        <div class="product-body">
                            <h3>@p.Name</h3>
                            <p>@(string.IsNullOrEmpty(p.Category) ? "High quality product." : p.Category + " category.")</p>
                        </div>
                        <div class="product-footer">
                            <span class="price">&#8377;@p.Price</span>
                            <object><a href="/Cart/Add?name=@Uri.EscapeDataString(p.Name)&price=@((int)p.Price)&image=@Uri.EscapeDataString(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "https://placehold.co/200x200?text=Product")" class="btn-add">
                                <i class="fa fa-shopping-cart"></i> Add
                            </a></object>
                        </div>
                    </div>
                </a>
            }
        }
        else
        {
            <p style="text-align:center; width:100%;">No products found. Please wait for Admin to stock up!</p>
        }
    </div>

    <!-- VIEW ALL BUTTON -->
    <div class="view-all-row">
        <a href="/Products/AllProducts" class="btn-view-all">View All Products</a>
    </div>

</section>