@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Home - SpareKart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- HERO SECTION -->
<div class="hero">
    <img src="/images/home.png" alt="SpareKart Banner" class="hero-img" />
</div>

<!-- FEATURED PRODUCTS -->
<section class="products-section">
    <h2 class="section-title">Featured Products</h2>

    <div class="products-grid">
        
        <!-- Product 1 -->
        <a href="/Products/ProductDetails?name=All Season Tyre&price=4500&image=tyre.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/tyre.jpg" alt="All-Season Tyre" class="product-img" />
                <div class="product-body">
                    <h3>All-Season Tyre</h3>
                    <p>Durable all-season tyre with excellent grip. Size: 195/65 R15.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;4500</span>
                    <object><a href="/Cart/Add?name=All Season Tyre&price=4500&image=tyre.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

        <!-- Product 2 -->
        <a href="/Products/ProductDetails?name=LED Headlight&price=1899&image=light.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/light.jpg" alt="LED Headlight" class="product-img" />
                <div class="product-body">
                    <h3>LED Headlight</h3>
                    <p>Bright LED headlight for better visibility. Easy installation.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;1899</span>
                    <object><a href="/Cart/Add?name=LED Headlight&price=1899&image=light.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

        <!-- Product 3 -->
        <a href="/Products/ProductDetails?name=Engine Oil Filter&price=499&image=engine.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/engine.jpg" alt="Engine Oil Filter" class="product-img" />
                <div class="product-body">
                    <h3>Engine Oil Filter</h3>
                    <p>High-quality oil filter for engine protection. Compatible with most car models.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;499</span>
                    <object><a href="/Cart/Add?name=Engine Oil Filter&price=499&image=engine.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

        <!-- Product 4 -->
        <a href="/Products/ProductDetails?name=Brake Disc Set&price=2999&image=brake.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/brake.jpg" alt="Brake Disc Set" class="product-img" />
                <div class="product-body">
                    <h3>Brake Disc Set</h3>
                    <p>Premium brake disc set for superior stopping power. Fits front wheels.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;2999</span>
                    <object><a href="/Cart/Add?name=Brake Disc Set&price=2999&image=brake.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

        <!-- Product 5 -->
        <a href="/Products/ProductDetails?name=All Season Tyre&price=4500&image=tyre.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/tyre.jpg" alt="All-Season Tyre" class="product-img" />
                <div class="product-body">
                    <h3>All-Season Tyre</h3>
                    <p>Durable all-season tyre with excellent grip. Size: 195/65 R15.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;4500</span>
                    <object><a href="/Cart/Add?name=All Season Tyre&price=4500&image=tyre.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

        <!-- Product 6 -->
        <a href="/Products/ProductDetails?name=Engine Oil Filter&price=499&image=engine.jpg" class="product-link">
            <div class="product-card">
                <img src="/images/engine.jpg" alt="Engine Oil Filter" class="product-img" />
                <div class="product-body">
                    <h3>Engine Oil Filter</h3>
                    <p>High-quality oil filter for engine protection. Compatible with most car models.</p>
                </div>
                <div class="product-footer">
                    <span class="price">&#8377;499</span>
                    <object><a href="/Cart/Add?name=Engine Oil Filter&price=499&image=engine.jpg" class="btn-add">
                        <i class="fa fa-shopping-cart"></i> Add
                    </a></object>
                </div>
            </div>
        </a>

    </div>

    <!-- VIEW ALL BUTTON -->
    <div class="view-all-row">
        <a href="/Products/AllProducts" class="btn-view-all">View All Products</a>
    </div>

</section>