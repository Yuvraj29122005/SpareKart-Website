@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/home.css" />

<!-- HERO -->

<div class="hero">
    <h1>Quality Car Spare Parts at Your <br /> Fingertips</h1>
    <p>Find the perfect parts for your vehicle with our extensive collection</p>
</div>

<!-- CATEGORY -->

<h3 class="title">Browse by Category</h3>

<div class="category">
    <div class="cat-card">Engine</div>
    <div class="cat-card">Brakes</div>
    <div class="cat-card">Tyres</div>
    <div class="cat-card">Lights</div>
    <div class="cat-card">Accessories</div>
</div>

<!-- PRODUCTS -->

<h3 class="title">Featured Products</h3>

<div class="products">

    <a href="/Product/ProductDetails" class="card-link">
        <div class="p-card">
            <img src="~/images/engine.jpg" />
            <h4>Engine Oil Filter</h4>
            <p class="desc">High-quality filter for engine protection.</p>
            <div class="bottom">
                <span>₹499</span>
                <button>Add</button>
            </div>
        </div>
    </a>

    <a href="/Product/ProductDetails" class="card-link">
        <div class="p-card">
            <img src="~/images/brake.jpg" />
            <h4>Brake Disc Set</h4>
            <p class="desc">Premium brake disc set.</p>
            <div class="bottom">
                <span>₹2999</span>
                <button>Add</button>
            </div>
        </div>
    </a>

    <a href="/Product/ProductDetails" class="card-link">
        <div class="p-card">
            <img src="~/images/tyre.jpg" />
            <h4>All Season Tyre</h4>
            <p class="desc">Durable tyre with grip.</p>
            <div class="bottom">
                <span>₹4500</span>
                <button>Add</button>
            </div>
        </div>
    </a>

    <a href="/Product/ProductDetails" class="card-link">
        <div class="p-card">
            <img src="~/images/light.jpg" />
            <h4>LED Headlight</h4>
            <p class="desc">Bright LED headlight.</p>
            <div class="bottom">
                <span>₹1899</span>
                <button>Add</button>
            </div>
        </div>
    </a>

</div>

<div class="view-btn">
    <a href="/Products/AllProducts">
        <button>View All Products</button>
    </a>
</div>